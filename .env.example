# Supabase — obten estos en supabase.com → Settings → API
REACT_APP_SUPABASE_URL=https://TU_PROYECTO.supabase.co
REACT_APP_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# Google Sheets — obten esto en console.cloud.google.com
REACT_APP_GOOGLE_API_KEY=TU_GOOGLE_API_KEY_AQUI

# ID de tu Google Sheet (el string largo en la URL entre /d/ y /edit)
REACT_APP_GOOGLE_SHEET_ID=TU_SHEET_ID_AQUI

# Nombre exacto de la hoja (tab) dentro del documento
REACT_APP_GOOGLE_SHEET_NAME=Sheet1
